# 데이터베이스 연결 정보
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Google OAuth 설정
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT 설정
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 서버 설정
PORT=3001
NODE_ENV=development

# 프론트엔드 URL (CORS용)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# 데이터베이스 동기화 (개발용, 프로덕션에서는 false)
SYNC_DB=false

# 외부 API (이커머스 등) - X-API-Key 헤더로 인증
# /api/external/inventory/* , POST /api/external/customers/sync 접근 시 필요
EXTERNAL_API_KEY=your-secret-api-key-change-this

# 몰→ERP 고객 동기화: 요청에 chamcharmMemberStatus 없을 때 쓸 CHAMCHARM_MEMBER_STATUS의 cd_value 또는 cd_name
# 미설정 시 CHAMCHARM_MEMBER → NEW_MALL_MEMBER → 참참회원 → 신규몰 참참회원 순으로 자동 매칭, 없으면 cd_order 최소인 비회원 제외 코드
# EXTERNAL_MALL_DEFAULT_CHAMCHARM_MEMBER_CD_VALUE=

# 카카오 로컬 API (주소 검색) — Kakao Developers REST API 키, 지도/로컬 API 활성화 필요
# KAKAO_REST_API_KEY=
